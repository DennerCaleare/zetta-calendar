# Copy this file to .env and fill in your Supabase project credentials.
# Find them at: Supabase Dashboard → Project Settings → API

# Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anonymous (public) key — safe to expose in the browser
VITE_SUPABASE_ANON_KEY=your-anon-key-here


# ─── Better Auth ────────────────────────────────────────────────────────────
# Gere com: npx @better-auth/cli@latest secret
BETTER_AUTH_SECRET=YOUR_SECRET_KEY

# URL base do app (localhost em dev, URL do Vercel em produção)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
